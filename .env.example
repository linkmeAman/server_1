# Dynamic Multi-Project API Configuration

# API Configuration
APP_NAME=Dynamic Multi-Project API
APP_VERSION=1.0.0
DEBUG=True

# Server Configuration
HOST=127.0.0.1
PORT=8010
RELOAD=True

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALLOWED_HOSTS=*
CORS_ORIGINS=*
CORS_MANAGED_BY_PROXY=False

# API Key Authentication (optional)
API_KEY_ENABLED=False
API_KEYS=

# Rate Limiting
RATE_LIMIT_ENABLED=False
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Database Configuration
# Option 1: Full database URL
DATABASE_URL=

# Option 2: Individual database parameters
DB_HOST=localhost
DB_USER=developer
DB_PASSWORD=DB_PASSWORD
DB_NAME=DB_NAME
DB_PORT=3306

# Central User DB (legacy user table + auth sidecar table)
# Option 1: Full URL (takes precedence)
CENTRAL_DATABASE_URL=
# Option 2: Individual parameters
DB_HOST=localhost
DB_USER=developer
DB_PASSWORD=DB_PASSWORD
CENTRAL_DB_NAME=user_db
DB_PORT=3306
# Backward-compatible alias used in local .env
DB_CENTRAL=user_db

# PASETO / Auth
PASETO_SECRET_KEY=change-this-paseto-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
RESET_TOKEN_EXPIRE_MINUTES=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Controller Security
ALLOW_PRIVATE_METHODS=False
MAX_CONTROLLER_NAME_LENGTH=50
MAX_FUNCTION_NAME_LENGTH=50
