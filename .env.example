# Dynamic Multi-Project API Configuration

# API Configuration
APP_NAME=Dynamic Multi-Project API
APP_VERSION=1.0.0
DEBUG=True

# Server Configuration
HOST=127.0.0.1
PORT=8010
RELOAD=True

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALLOWED_HOSTS=*
CORS_ORIGINS=*
CORS_MANAGED_BY_PROXY=False

# API Key Authentication (optional)
API_KEY_ENABLED=False
API_KEYS=

# Rate Limiting
RATE_LIMIT_ENABLED=False
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Database Configuration
# Option 1: Full database URL
DATABASE_URL=
DATABASE_MAIN_URL=

# Option 2: Individual database parameters
DB_HOST=localhost
DB_USER=developer
DB_PASSWORD=DB_PASSWORD
DB_NAME=DB_NAME
DB_PORT=3306

# Central User DB (legacy user table + auth sidecar table)
# Option 1: Full URL (takes precedence)
CENTRAL_DATABASE_URL=
DATABASE_CENTRAL_URL=
# Option 2: Individual parameters
DB_HOST=localhost
DB_USER=developer
DB_PASSWORD=DB_PASSWORD
CENTRAL_DB_NAME=user_db
DB_PORT=3306
# Backward-compatible alias used in local .env
DB_CENTRAL=user_db

# PASETO / Auth
PASETO_SECRET_KEY=change-this-paseto-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
RESET_TOKEN_EXPIRE_MINUTES=30

# Google Calendar V1
GOOGLE_CALENDAR_API_BASE_URL=https://www.googleapis.com/calendar/v3
GOOGLE_CALENDAR_TIMEOUT_SECONDS=20
GOOGLE_CALENDAR_COMPARE_TIMEZONE=Asia/Kolkata
GOOGLE_CALENDAR_ID=primary
GOOGLE_DRIVE_TOKEN_ID=2
GOOGLE_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_TOKEN_REFRESH_SKEW_SECONDS=120

# Employee Events V1
EMP_EVENT_APPROVED_STATUS=1
EMP_EVENT_PARKED_VALUE=1
EMP_EVENT_TIMEZONE=Asia/Kolkata
EMP_EVENT_ENABLE_GOOGLE_SYNC=true

# Auth v2
AUTH_V2_ENABLED=False
AUTH_V2_ISSUER=dynamic-api-auth-v2
AUTH_V2_AUDIENCE=dynamic-api-clients
AUTH_V2_ACCESS_TOKEN_MINUTES=15
AUTH_V2_REFRESH_TOKEN_DAYS=7
AUTH_V2_TOKEN_VERSION=2
AUTH_V2_CURRENT_KID=v2-kid-1
AUTH_V2_SIGNING_KEYS_JSON=[{"kid":"v2-kid-1","secret":"change-me","valid_from":"2026-01-01T00:00:00+00:00","valid_until":"2030-01-01T00:00:00+00:00","status":"active"}]
AUTH_V2_REFRESH_HASH_PEPPER=change-this-refresh-pepper
AUTH_V2_TIMING_FLOOR_MS=400
AUTH_V2_TIMING_JITTER_MIN_MS=25
AUTH_V2_TIMING_JITTER_MAX_MS=80
AUTH_V2_RATE_LIMIT_IP_10M=120
AUTH_V2_RATE_LIMIT_IP_MOBILE_10M=30
AUTH_V2_RATE_LIMIT_MOBILE_GLOBAL_10M=40
AUTH_V2_LOGIN_FAIL_THRESHOLD=5
AUTH_V2_LOGIN_FAIL_WINDOW_MINUTES=15
AUTH_V2_LOGIN_COOLDOWN_MINUTES=15
AUTH_V2_BOOTSTRAP_ONLY=True

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Controller Security
ALLOW_PRIVATE_METHODS=False
MAX_CONTROLLER_NAME_LENGTH=50
MAX_FUNCTION_NAME_LENGTH=50

# SQL Gateway (single-table structured DSL)
# SQL_GATEWAY_ALLOWLIST_SOURCE=auto
SQL_GATEWAY_ALLOWLIST_SOURCE=db
# SQL_GATEWAY_ALLOWLIST_JSON={"venue":{"db":"STORE","table_kind":"table","operations":["select","insert","update","delete"],"select_columns":["id","venue","city","status","park","created_by","updated_by"],"filter_columns":["id","city","status","park"],"group_columns":["city","status","park"],"order_columns":["id","city"],"insert_columns":["venue","city","status","created_by","updated_by"],"update_columns":["status","park","updated_by"],"max_write_rows":100,"allow_explicit_pk_insert":false},"emp_cont_view":{"db":"STORE","table_kind":"view","operations":["select"],"select_columns":["emp_id","name"],"filter_columns":["emp_id","name"],"group_columns":["emp_id"],"order_columns":["emp_id"]}}
SQL_GATEWAY_ALLOWLIST_PATH=
# SQL_GATEWAY_DB_ENGINE_MAP_JSON={"STORE":"default","CENTRAL":"central","DEFAULT":"default"}
SQL_GATEWAY_DB_ENGINE_MAP_JSON={"STORE":"default","CENTRAL":"central"}
SQL_GATEWAY_ENABLE_TOTAL_COUNT=True
SQL_GATEWAY_DEFAULT_LIMIT=100
SQL_GATEWAY_MAX_LIMIT=1000
SQL_GATEWAY_MAX_FILTERS=25
SQL_GATEWAY_MAX_IN_LIST=200
SQL_GATEWAY_MAX_COLUMNS=50
SQL_GATEWAY_MAX_ORDER_BY=5
SQL_GATEWAY_MAX_GROUP_BY=10
SQL_GATEWAY_MAX_BULK_INSERT_ROWS=500
SQL_GATEWAY_MAX_BODY_BYTES=1048576
SQL_GATEWAY_MAX_WRITE_ROWS_DEFAULT=100
SQL_GATEWAY_RATE_LIMIT_PER_MINUTE=120
SQL_GATEWAY_STATEMENT_TIMEOUT_MS=15000
SQL_GATEWAY_POLICY_CACHE_TTL_SECONDS=60
SQL_GATEWAY_SCHEMA_CACHE_TTL_SECONDS=600
# Internal SQLGW admin RBAC guard (set False only for temporary single-user/dev usage)
# SQLGW_ADMIN_REQUIRE_RBAC=True
SQLGW_ADMIN_REQUIRE_RBAC=False
